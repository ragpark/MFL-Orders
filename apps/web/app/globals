@tailwind base;
@tailwind components;
@tailwind utilities;
body { @apply bg-slate-50 text-slate-900; }
.card { @apply rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200; }
.btn { @apply rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 disabled:opacity-50; }
.input { @apply rounded-lg border border-slate-300 px-3 py-2 text-sm; }
.tab { @apply rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100; }
